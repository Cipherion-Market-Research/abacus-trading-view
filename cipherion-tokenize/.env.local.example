# =============================================================================
# CipheX Atlas — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Only NEXT_PUBLIC_SOLANA_NETWORK is required. Everything else enhances the demo.

# --- REQUIRED ---

# Solana network: devnet | mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# --- RECOMMENDED FOR DEMO ---

# Helius RPC endpoint (free tier: 1M credits/month)
# Sign up: https://helius.dev → Dashboard → Create API Key → Copy devnet URL
# Without this, the public devnet RPC rate-limits at 100 req/10s and the
# transaction history tab will fail with 429 errors.
#
# The key is exposed to the browser (wallet adapter needs a reachable RPC).
# Production: lock it down in the Helius dashboard under RPCs → Access Control
# → Allowed Domains, adding only your production domain.
#
# IMPORTANT: Helius does NOT accept "localhost" as an allowed domain (the UI
# rejects it with "localhost is not a valid domain in this context"). For local
# development, leave Allowed Domains EMPTY. If you set any rule that doesn't
# match the browser origin, every paid RPC method (getBalance, getAccountInfo,
# etc.) returns JSON-RPC error -32401 Unauthorized — even though getHealth
# still works, which makes the failure look like a key/CORS issue.
#
# If you want zero key exposure, build a server-side /api/rpc proxy route and
# move the Helius URL to a server-only HELIUS_RPC_ENDPOINT var.
NEXT_PUBLIC_RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Pinata IPFS — for token image drag-and-drop uploads (free tier: 1GB)
# Sign up: https://app.pinata.cloud → API Keys → New Key
# Permissions: check "pinFileToIPFS" only.
#
# SERVER-ONLY. Uploads go through /api/ipfs/upload — the JWT never reaches the
# browser. Do NOT prefix with NEXT_PUBLIC_ or anyone can scrape it from the JS
# bundle and upload to your Pinata account.
PINATA_JWT=your_pinata_jwt_here

# Gateway hostname — read by both the server upload route and the browser
# when rendering ipfs:// URIs. Safe to expose (it's just a hostname).
NEXT_PUBLIC_PINATA_GATEWAY=gateway.pinata.cloud

# Upstash Redis — backs the public /explorer catalog.
# Vercel: Marketplace → Upstash → add the integration → connect to project.
# This auto-populates both vars. For local dev: copy from the Upstash console.
# SERVER-ONLY. Without these, token creation still works, but the /explorer
# catalog shows a 'Registry not configured' banner.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- OPTIONAL ---

# Transfer Hook program ID (Phase 1B — leave empty for Phase 1A)
NEXT_PUBLIC_TRANSFER_HOOK_PROGRAM_ID=
